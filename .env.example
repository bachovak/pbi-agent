# ── Anthropic (required) ──────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Power BI Model (required) ─────────────────────────────────────────────────
# Full path to your Model.bim file exported from Tabular Editor
# Windows example:  BIM_PATH=C:\Users\yourname\Documents\MyModel\Model.bim
# Mac/Linux example: BIM_PATH=/Users/yourname/documents/mymodel/Model.bim
BIM_PATH=C:\path\to\your\Model.bim

# ── Power BI REST API (optional) ──────────────────────────────────────────────
# Only needed if you want to push measures directly to Power BI via pbi_connector.py
# How to get these values:
#   1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#   2. Register a new app (or use an existing one)
#   3. Under "API permissions" add: Power BI Service → Dataset.ReadWrite.All
#   4. Under "Certificates & secrets" create a new client secret
#   5. Copy the values below from your app registration

PBI_CLIENT_ID=your_azure_app_client_id
PBI_TENANT_ID=your_azure_tenant_id
PBI_CLIENT_SECRET=your_azure_client_secret

# Found in Power BI service URL when viewing your workspace:
# https://app.powerbi.com/groups/<WORKSPACE_ID>/...
PBI_WORKSPACE_ID=your_powerbi_workspace_id

# Found in Power BI service URL when viewing your dataset settings
PBI_DATASET_ID=your_powerbi_dataset_id
