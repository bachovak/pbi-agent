        "partitions": [
          {
            "name": "Fact_PackageForecast",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Folder.Files(FolderPath_PackageForecast),",
                "",
                "    ExcelFilesOnly = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower(Text.End([Name], 5)) = \".xlsx\"",
                "    ),",
                "",
                "    ProcessFile = (fileContent as binary) as table =>",
                "        let",
                "            Workbook = Excel.Workbook(fileContent, true, true),",
                "",
                "            Sheet =",
                "                let",
                "                    matching = Table.SelectRows(Workbook, each [Name] = \"Report\")",
                "                in",
                "                    if Table.RowCount(matching) > 0",
                "                    then matching{0}[Data]",
                "                    else Workbook{0}[Data],",
                "",
                "            // Work with raw rows — no PromoteHeaders needed",
                "            AllRows = Table.ToRows(Sheet),",
                "",
                "            // Extract run date from row 4 (index 3), column A",
                "            RunDateRaw  = AllRows{3}{0},",
                "            RunDateText = if RunDateRaw <> null",
                "                          then Text.AfterDelimiter(Text.From(RunDateRaw), \"Run Date: \")",
                "                          else null,",
                "            RunDate = try fnParseOperaDate(Text.Trim(RunDateText), DateFormat) otherwise null,",
                "",
                "            // Data rows start at row 8 (index 7), headers are row 7 (index 6)",
                "            // Skip rows 1-7 entirely and work directly with data",
                "            DataRows = List.Skip(AllRows, 7),",
                "",
                "            // Keep only rows where:",
                "            // - Column A (index 0) is a date/datetime (real data rows)",
                "            // - NOT text strings like \"Daily Total\", \"GRAND TOTAL\", \"***\"",
                "            FilteredRows = List.Select(",
                "                DataRows,",
                "                each",
                "                    let v = _{0}",
                "                    in",
                "                        v <> null",
                "                        and (Value.Is(v, type date) or Value.Is(v, type datetime) or Value.Is(v, type number))",
                "            ),",
                "",
                "            // Convert list of lists to table with explicit column names",
                "            AsTable = Table.FromRows(",
                "                FilteredRows,",
                "                {",
                "                    \"StayDate_Raw\", \"DayName\", \"PackageCode\", \"PackageDescription\",",
                "                    \"Rooms\", \"Adults\", \"Children\",",
                "                    \"RoomRevenue\", \"PackageRevenue\", \"FBRevenue\", \"OtherRevenue\",",
                "                    \"TotalPackageValue\", \"AvgPackageRate\", \"BARRate\",",
                "                    \"PackageUplift\", \"PaxCovers\"",
                "                }",
                "            ),",
                "",
                "            // Parse Stay Date — handle datetime from Excel",
                "            ParseDates = Table.AddColumn(",
                "                AsTable,",
                "                \"StayDate\",",
                "                each",
                "                    let raw = [StayDate_Raw]",
                "                    in",
                "                        if raw = null then null",
                "                        else if Value.Is(raw, type date)     then raw",
                "                        else if Value.Is(raw, type datetime) then DateTime.Date(raw)",
                "                        else if Value.Is(raw, type number)   then Date.From(raw)",
                "                        else try fnParseOperaDate(Text.From(raw), DateFormat) otherwise null,",
                "                type date",
                "            ),",
                "",
                "            DropRaw = Table.RemoveColumns(ParseDates, {\"StayDate_Raw\"}),",
                "",
                "            // Set types",
                "            WithTypes = Table.TransformColumnTypes(",
                "                DropRaw,",
                "                {",
                "                    {\"StayDate\",          type date},",
                "                    {\"DayName\",           type text},",
                "                    {\"PackageCode\",       type text},",
                "                    {\"PackageDescription\",type text},",
                "                    {\"Rooms\",             Int64.Type},",
                "                    {\"Adults\",            Int64.Type},",
                "                    {\"Children\",          Int64.Type},",
                "                    {\"PaxCovers\",         Int64.Type},",
                "                    {\"RoomRevenue\",       type number},",
                "                    {\"PackageRevenue\",    type number},",
                "                    {\"FBRevenue\",         type number},",
                "                    {\"OtherRevenue\",      type number},",
                "                    {\"TotalPackageValue\", type number},",
                "                    {\"AvgPackageRate\",    type number},",
                "                    {\"BARRate\",           type number},",
                "                    {\"PackageUplift\",     type number}",
                "                }",
                "            ),",
                "",
                "            // Add RunDate and ForecastDay",
                "            WithRunDate = Table.AddColumn(WithTypes,   \"RunDate\",     each RunDate, type date),",
                "            WithDayNum  = Table.AddColumn(WithRunDate, \"ForecastDay\",",
                "                each",
                "                    if [StayDate] = null or RunDate = null then null",
                "                    else Duration.Days([StayDate] - RunDate) + 1,",
                "                Int64.Type",
                "            ),",
                "",
                "            // Reorder columns",
                "            Final = Table.SelectColumns(",
                "                WithDayNum,",
                "                {",
                "                    \"StayDate\", \"DayName\", \"ForecastDay\", \"RunDate\",",
                "                    \"PackageCode\", \"PackageDescription\",",
                "                    \"Rooms\", \"Adults\", \"Children\", \"PaxCovers\",",
                "                    \"RoomRevenue\", \"PackageRevenue\", \"FBRevenue\",",
                "                    \"OtherRevenue\", \"TotalPackageValue\",",
                "                    \"AvgPackageRate\", \"BARRate\", \"PackageUplift\"",
                "                },",
                "                MissingField.Ignore",
                "            )",
                "        in",
                "            Final,",
                "",
                "    AddProcessed = Table.AddColumn(",
                "        ExcelFilesOnly,",
                "        \"Processed\",",
                "        each ProcessFile([Content])",
                "    ),",
                "",
                "    Expanded = Table.ExpandTableColumn(",
                "        AddProcessed,",
                "        \"Processed\",",
                "        {",
                "            \"StayDate\", \"DayName\", \"ForecastDay\", \"RunDate\",",
                "            \"PackageCode\", \"PackageDescription\",",
                "            \"Rooms\", \"Adults\", \"Children\", \"PaxCovers\",",
                "            \"RoomRevenue\", \"PackageRevenue\", \"FBRevenue\",",
                "            \"OtherRevenue\", \"TotalPackageValue\",",
                "            \"AvgPackageRate\", \"BARRate\", \"PackageUplift\"",
                "        },",
                "        {",
                "            \"StayDate\", \"DayName\", \"ForecastDay\", \"RunDate\",",
                "            \"PackageCode\", \"PackageDescription\",",
                "            \"Rooms\", \"Adults\", \"Children\", \"PaxCovers\",",
                "            \"RoomRevenue\", \"PackageRevenue\", \"FBRevenue\",",
                "            \"OtherRevenue\", \"TotalPackageValue\",",
                "            \"AvgPackageRate\", \"BARRate\", \"PackageUplift\"",
                "        }",
                "    ),",
                "",
                "    // Keep most recent run per StayDate + PackageCode",
                "    SortByRunDate = Table.Sort(",
                "        Expanded,",
                "        {{\"RunDate\", Order.Descending}, {\"StayDate\", Order.Ascending}}",
                "    ),",
                "",
                "    RemoveDuplicates = Table.Distinct(",
                "        SortByRunDate,",
                "        {\"StayDate\", \"PackageCode\"}",
                "    ),",
                "",
                "    SortFinal = Table.Sort(",
                "        RemoveDuplicates,",
                "        {{\"StayDate\", Order.Ascending}, {\"PackageCode\", Order.Ascending}}",
                "    ),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(SortFinal,{{\"TotalPackageValue\", Currency.Type}, {\"AvgPackageRate\", Currency.Type}, {\"BARRate\", Currency.Type}, {\"PackageUplift\", Currency.Type}, {\"RoomRevenue\", Currency.Type}, {\"PackageRevenue\", Currency.Type}, {\"FBRevenue\", Currency.Type}, {\"OtherRevenue\", Currency.Type}, {\"Rooms\", Int64.Type}, {\"Adults\", Int64.Type}, {\"Children\", Int64.Type}, {\"PaxCovers\", Int64.Type}, {\"ForecastDay\", Int64.Type}})",
                "",
                "in",
                "    #\"Changed Type\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
