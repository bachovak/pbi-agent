            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Profile Room Revenue",
            "expression": "SUM(Fact_ProfileProduction[RoomRevenue])",
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Profile Production",
            "lineageTag": "94fce60b-c846-40f1-9636-91129848a8d4"
          },
          {
            "name": "Profile Total Revenue",
            "expression": "SUM(Fact_ProfileProduction[TotalRevenue])",
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Profile Production",
            "lineageTag": "ac681997-e58b-4b1b-bb61-8b77b7d09de7"
          },
          {
            "name": "Profile FB Revenue",
            "expression": "SUM(Fact_ProfileProduction[FBRevenue])",
