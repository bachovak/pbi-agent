              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Profile ADR",
            "expression": [
              "",
              "DIVIDE(",
              "    [Profile Room Revenue],",
              "    [Profile Room Nights]",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Profile Production",
            "lineageTag": "6c45d62e-f809-41d4-aff9-8210cd64ebe6"
          },
          {
            "name": "Profile Avg LOS",
            "expression": [
              "",
              "AVERAGE(Fact_ProfileProduction[AvgLengthOfStay])"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "b3bf7f99-4a6e-4d18-8af0-011a6603e0d5",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Profile Cancellation Rate",
            "expression": [
              "DIVIDE(",
              "    SUM(Fact_ProfileProduction[CancelledReservations]),",
              "    SUM(Fact_ProfileProduction[ReservationArrivals]) + ",
              "    SUM(Fact_ProfileProduction[CancelledReservations])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Profile Production",
            "lineageTag": "f9cf7af9-d658-4355-ae55-a44c6c09ac06"
          },
          {
            "name": "Profile Revenue Mix %",
            "expression": [
              "",
              "DIVIDE(",
              "    [Profile Total Revenue],",
              "    CALCULATE([Profile Total Revenue], ALL(Fact_ProfileProduction))",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Profile Production",
            "lineageTag": "d82a8d1b-9949-466a-a060-e091e81b05b3"
          },
          {
            "name": "Profile Block %",
            "expression": [
              "",
              "DIVIDE(",
              "    SUM(Fact_ProfileProduction[BlockRoomNights]),",
              "    [Profile Room Nights]",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Profile Production",
            "lineageTag": "459ec8ea-026a-4253-8d34-cb706204f35a"
          },
          {
            "name": "Profile No Show Rate",
            "expression": [
              "",
              "DIVIDE(",
              "    SUM(Fact_ProfileProduction[NoShowReservations]),",
              "    SUM(Fact_ProfileProduction[ReservationArrivals])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Profile Production",
            "lineageTag": "95e562b0-8169-4b77-9696-d73578d8b3d3"
          },
          {
            "name": "Active Accounts",
            "expression": [
              "",
              "DISTINCTCOUNT(Fact_ProfileProduction[ProfileName])"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "8f05bd9c-febc-4d03-a640-a41268e48f3d",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Avg Revenue per Account",
            "expression": [
              "",
              "DIVIDE(",
              "    [Profile Total Revenue],",
              "    [Active Accounts]",
              ")"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "2583480c-be10-4cec-9291-01077d189a20",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Avg Room Nights per Account",
            "expression": [
              "",
              "DIVIDE(",
              "    [Profile Room Nights],",
              "    [Active Accounts]",
              ")"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "e0d64faf-9c3f-43b1-bcb5-9895b8a53ea9",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Revenue Concentration Top3",
            "expression": [
              "",
              "VAR Top3Revenue =",
              "    SUMX(",
              "        TOPN(",
              "            3,",
              "            VALUES(Fact_ProfileProduction[ProfileName]),",
              "            [Profile Total Revenue],",
              "            DESC",
              "        ),",
              "        [Profile Total Revenue]",
              "    )",
              "RETURN",
              "DIVIDE(Top3Revenue, [Profile Total Revenue])"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "1ab94e07-8cc4-4dbd-963b-3a732144b3c7",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Concentration Warning",
            "expression": [
              "",
              "VAR Pct = [Revenue Concentration Top3]",
              "RETURN",
              "IF(",
              "    Pct >= 0.60,",
              "    \"⚠  Top 3 accounts = \" & FORMAT(Pct, \"0.0%\") & \" of revenue — high concentration risk\",",
              "    IF(",
              "        Pct >= 0.40,",
              "        \"⚡  Top 3 accounts = \" & FORMAT(Pct, \"0.0%\") & \" — consider diversifying\",",
              "        \"✓  Healthy mix — top 3 accounts = \" & FORMAT(Pct, \"0.0%\")",
              "    )",
              ")"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "91d0dd6a-46a8-4bc4-8b9e-f660b206f547",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Profile Revenue per Room Night",
            "expression": [
              "",
              "DIVIDE(",
              "    [Profile Total Revenue],",
              "    [Profile Room Nights]",
              ")"
            ],
            "displayFolder": "Profile Production",
            "lineageTag": "6b093291-2c19-402f-be37-70d98ca8c310",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Report Period",
            "expression": [
              "",
              "\"Period: \" &",
              "FORMAT(MIN(Fact_ProfileProduction[ReportDateFrom]), \"DD MMM YYYY\") &",
              "\" — \" &",
              "FORMAT(MAX(Fact_ProfileProduction[ReportDateTo]), \"DD MMM YYYY\")"
            ],
            "displayFolder": "Report Config",
            "lineageTag": "69641d5c-260b-4a44-8b23-5e8bfd4dc69d",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Profile Room Nights Mix %",
            "expression": [
              "",
              "DIVIDE(",
              "    [Profile Room Nights],",
              "    CALCULATE([Profile Room Nights], ALL(Fact_ProfileProduction))",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Profile Production",
            "lineageTag": "f8868307-68fd-4fa2-8496-044a78d2258c"
          },
          {
            "name": "Room Revenue MTD",
            "expression": [
              "",
              "TOTALMTD([Room Revenue], DimDate[Date])"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Daily Flash",
            "lineageTag": "3b550e17-5754-491a-bdda-6b76b1d931fe"
          },
          {
            "name": "Occupancy % MTD",
            "expression": [
              "",
              "DIVIDE(",
              "    TOTALMTD(SUM(Fact_DailyFlash[RoomsOccupied]), DimDate[Date]),",
              "    TOTALMTD(SUM(Fact_DailyFlash[RoomsAvailable]), DimDate[Date])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Daily Flash",
            "lineageTag": "f4a8d9de-6238-4cd6-9e59-f7dc34c09cc0"
          },
          {
            "name": "ADR MTD",
            "expression": [
              "",
              "DIVIDE(",
              "    TOTALMTD([Room Revenue], DimDate[Date]),",
              "    TOTALMTD(SUM(Fact_DailyFlash[RoomsOccupied]), DimDate[Date])",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Daily Flash",
            "lineageTag": "df773ef7-699d-4d3f-888c-4e4ab2e244db"
          },
          {
            "name": "RevPAR MTD",
            "expression": [
              "",
              "DIVIDE(",
              "    TOTALMTD([Room Revenue], DimDate[Date]),",
              "    TOTALMTD(SUM(Fact_DailyFlash[RoomsAvailable]), DimDate[Date])",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Daily Flash",
            "lineageTag": "23c16785-7109-4de2-83cf-f98085b3dd8f"
          },
          {
            "name": "Room Revenue MTD LY",
            "expression": [
              "",
              "CALCULATE(",
              "    [Room Revenue MTD],",
              "    SAMEPERIODLASTYEAR(DimDate[Date])",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Daily Flash",
            "lineageTag": "b2cb93c4-49cf-454a-921f-e4d906deda77"
          },
          {
            "name": "Room Revenue MTD vs LY %",
            "expression": [
              "",
              "VAR Result =",
              "    DIVIDE(",
              "        [Room Revenue MTD] - [Room Revenue MTD LY],",
              "        [Room Revenue MTD LY]",
              "    )",
              "RETURN",
              "IF(",
              "    ISBLANK(Result),",
              "    BLANK(),",
              "    IF(Result >= 0, \"+\" , \"-\")",
              "        & FORMAT(ABS(Result), \"0.0%\")",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Daily Flash",
            "lineageTag": "da107c79-0bda-48dc-bf8e-8e23a9e6905c"
          },
          {
            "name": "Occupancy % LY",
            "expression": [
              "",
              "CALCULATE(",
              "    [Occupancy %],",
              "    SAMEPERIODLASTYEAR('DimDate'[Date])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Daily Flash",
            "lineageTag": "b18d9ae9-cc7e-419c-bb28-418ab11b614c"
          },
          {
            "name": "Total Reservations",
            "expression": "COALESCE(COUNTROWS(Fact_Reservations), 0)",
            "displayFolder": "Reservations",
            "lineageTag": "74f2643d-95ab-4bc0-8b01-c06c922a9c64",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "New Bookings Today",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
              "        DimDate[Date] = TODAY()",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "7db350a9-6724-4b94-bf0b-23894da7ed98"
          },
          {
            "name": "New Bookings Yesterday",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
              "        DimDate[Date] = TODAY() - 1",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "10f24e13-ff2f-4922-978c-da84463853a1"
          },
          {
            "name": "New Bookings Last 7 Days",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
              "        DimDate[Date] >= TODAY() - 7,",
              "        DimDate[Date] <= TODAY()",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "06e58abb-53fc-42c0-9a40-879938790f88"
          },
          {
            "name": "New Bookings Last 30 Days",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
              "        DimDate[Date] >= TODAY() - 30,",
              "        DimDate[Date] <= TODAY()",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "8c26dfff-74b1-48fe-ab64-37df44fa9b43"
          },
          {
            "name": "Cancellations Last 7 Days",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        Fact_Reservations[ReservationStatus] = \"Cancelled\",",
              "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
              "        DimDate[Date] >= TODAY() - 7,",
              "        DimDate[Date] <= TODAY()",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "4aaf9347-27d3-4fd4-8a2c-3d9c7c45176c"
          },
          {
            "name": "Revenue on Books",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        SUM(Fact_Reservations[TotalRateRevenue]),",
              "        Fact_Reservations[ReservationStatus] = \"Reserved\"",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Reservations",
            "lineageTag": "f03f48d5-2660-4270-aa3a-a90fd7d805da"
          },
          {
            "name": "Arrivals Next 7 Days",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        Fact_Reservations[ReservationStatus] = \"Reserved\",",
              "        Fact_Reservations[ArrivalDate] >= TODAY(),",
              "        Fact_Reservations[ArrivalDate] <= TODAY() + 7",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "a48c1598-766c-4390-8e04-4ef4f8f7c7ea"
          },
          {
            "name": "Arrivals Next 30 Days",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        Fact_Reservations[ReservationStatus] = \"Reserved\",",
              "        Fact_Reservations[ArrivalDate] >= TODAY(),",
              "        Fact_Reservations[ArrivalDate] <= TODAY() + 30",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "79e64966-d04a-4dde-a105-0fd8d4ebedc1"
          },
          {
            "name": "Nights on Books",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        SUM(Fact_Reservations[Nights]),",
              "        Fact_Reservations[ReservationStatus] = \"Reserved\"",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "31a5bc32-a841-45ca-a657-16b5288c6595"
          },
          {
            "name": "Bookings per Day 30D",
            "expression": [
              "",
              "DIVIDE([New Bookings Last 30 Days], 30, 0)"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "41fe598b-4ca3-40bd-9cc6-31a0822a0678"
          },
          {
            "name": "Net Bookings Last 7 Days",
            "expression": [
              "",
              "[New Bookings Last 7 Days] - [Cancellations Last 7 Days]"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "f2780666-f098-4986-ada5-3dbada142e7b"
          },
          {
            "name": "No Show Count",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        Fact_Reservations[ReservationStatus] = \"No Show\"",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "6b8a2e95-4d5e-43bb-87e6-9a33235c1bc2"
          },
          {
            "name": "No Show Rate %",
            "expression": [
              "",
              "DIVIDE([No Show Count], [Total Reservations], 0)"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Reservations",
            "lineageTag": "663bd779-4063-42fc-8239-a3e6fd1b5734"
          },
          {
            "name": "Avg Rate on Books",
            "expression": [
              "",
              "DIVIDE(",
              "    [Revenue on Books],",
              "    [Nights on Books],",
              "    BLANK()",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Reservations",
            "lineageTag": "064cef7c-7738-4ee6-8887-0adba070155c"
          },
          {
            "name": "Page Title Sales Daily",
            "expression": [
              "",
              "VAR HotelName =",
              "    CALCULATE(",
              "        LOOKUPVALUE(Params[Value], Params[Parameter], \"HotelName\"),",
              "        ALL(Params)",
              "    )",
              "RETURN",
              "IF(ISBLANK(HotelName), \"Hotel Name\", HotelName) & \"  |  Sales Daily\""
            ],
            "displayFolder": "Report Config",
            "lineageTag": "5b0b4dcf-7ec8-43a0-8e51-5b24a55d6b78",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "_4 Page Title",
            "expression": [
              "",
              "VAR HotelName = LOOKUPVALUE(Params[Value], Params[Parameter], \"HotelName\")",
              "RETURN",
              "HotelName & \"  |  Sales Daily\""
            ],
            "displayFolder": "Report Config",
            "lineageTag": "024cc0fd-4b15-4a7c-9068-685ff1e3058c",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Today Label",
            "expression": [
              "",
              "\"Business Date: \" & FORMAT(TODAY(), \"DD MMM YYYY\")"
            ],
            "displayFolder": "Report Config",
            "lineageTag": "db2f4ed0-45fc-457f-977e-c942a3f3a6d2",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Bookings by Date",
            "expression": [
              "",
              "COALESCE(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date])",
              "    ),",
              "    0",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Reservations",
            "lineageTag": "44726b51-02af-4584-bf9d-55b890b51000"
          },
          {
            "name": "Is Arriving This Week",
            "expression": [
              "",
              "IF(",
              "    CALCULATE(",
              "        COUNTROWS(Fact_Reservations),",
              "        Fact_Reservations[ReservationStatus] = \"Reserved\",",
              "        Fact_Reservations[ArrivalDate] >= TODAY(),",
              "        Fact_Reservations[ArrivalDate] <= TODAY() + 7",
              "    ) > 0,",
              "    1,",
              "    0",
              ")"
            ],
            "displayFolder": "Reservations",
            "lineageTag": "5f8e779f-6a3c-4c8b-8b0f-a23eafc27309",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          }
        ],
        "changedProperties": [
          {
            "property": "IsHidden"
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
      {
        "name": "Time Intelligence",
        "lineageTag": "f62afa4c-b0f0-46f7-9c5f-8dd577e08ac4",
        "calculationGroup": {
          "calculationItems": [
            {
              "name": "Actual",
              "expression": "SELECTEDMEASURE()",
              "ordinal": 0
            },
            {
              "name": "LY",
              "expression": [
                "CALCULATE(",
                "    SELECTEDMEASURE(),",
                "    SAMEPERIODLASTYEAR(DimDate[Date])",
                ")"
              ],
              "ordinal": 1
            },
            {
              "name": "vs LY",
              "expression": [
                "SELECTEDMEASURE() - ",
                "CALCULATE(",
                "    SELECTEDMEASURE(),",
                "    SAMEPERIODLASTYEAR(DimDate[Date])",
                ")"
              ],
              "ordinal": 2
            },
            {
              "name": " vs LY %",
              "expression": [
                "DIVIDE(",
                "    SELECTEDMEASURE() - ",
                "    CALCULATE(",
                "        SELECTEDMEASURE(),",
                "        SAMEPERIODLASTYEAR(DimDate[Date])",
                "    ),",
                "    CALCULATE(",
                "        SELECTEDMEASURE(),",
                "        SAMEPERIODLASTYEAR(DimDate[Date])",
                "    )",
                ")"
              ],
              "ordinal": 3,
              "formatStringDefinition": {
                "expression": "\"0.0%\""
              }
            },
            {
              "name": "MTD",
              "expression": "TOTALMTD(SELECTEDMEASURE(), DimDate[Date])",
              "ordinal": 4
            },
            {
              "name": "MTD LY",
              "expression": [
                "CALCULATE(",
                "    TOTALMTD(SELECTEDMEASURE(), DimDate[Date]),",
                "    SAMEPERIODLASTYEAR(DimDate[Date])",
                ")"
              ],
              "ordinal": 5
            },
            {
              "name": "MTD vs LY %",
              "expression": [
                "DIVIDE(",
                "    TOTALMTD(SELECTEDMEASURE(), DimDate[Date]) -",
                "    CALCULATE(",
                "        TOTALMTD(SELECTEDMEASURE(), DimDate[Date]),",
                "        SAMEPERIODLASTYEAR(DimDate[Date])",
                "    ),",
                "    CALCULATE(",
                "        TOTALMTD(SELECTEDMEASURE(), DimDate[Date]),",
                "        SAMEPERIODLASTYEAR(DimDate[Date])",
                "    )",
                ")"
              ],
              "ordinal": 6,
              "formatStringDefinition": {
                "expression": "\"0.0%\""
              }
            },
            {
              "name": "YTD",
              "expression": "TOTALYTD(SELECTEDMEASURE(), DimDate[Date])",
              "ordinal": 7
            },
            {
              "name": "YTD LY",
              "expression": [
                "CALCULATE(",
                "    TOTALYTD(SELECTEDMEASURE(), DimDate[Date]),",
                "    SAMEPERIODLASTYEAR(DimDate[Date])",
                ")"
              ],
              "ordinal": 8
            },
            {
              "name": "YTD vs LY %",
              "expression": [
                "DIVIDE(",
                "    TOTALYTD(SELECTEDMEASURE(), DimDate[Date]) -",
                "    CALCULATE(",
                "        TOTALYTD(SELECTEDMEASURE(), DimDate[Date]),",
                "        SAMEPERIODLASTYEAR(DimDate[Date])",
                "    ),",
                "    CALCULATE(",
                "        TOTALYTD(SELECTEDMEASURE(), DimDate[Date]),",
                "        SAMEPERIODLASTYEAR(DimDate[Date])",
                "    )",
                ")"
              ],
              "ordinal": 9,
              "formatStringDefinition": {
                "expression": "\"0.0%\""
              }
            }
          ]
        },
        "columns": [
          {
            "name": "Time Calculation",
            "dataType": "string",
