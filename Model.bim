            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Table.FromRows(",
                "        {",
                "            {\"BB\",       \"Bed & Breakfast\",       \"F&B\",   false},",
                "            {\"HB\",       \"Half Board\",            \"F&B\",   false},",
                "            {\"FB\",       \"Full Board\",             \"F&B\",   false},",
                "            {\"SPABRK\",   \"Spa Break\",             \"Spa\",   false},",
                "            {\"ROMANCE\",  \"Romance Package\",        \"Other\", false},",
                "            {\"GOLF\",     \"Golf & Stay\",           \"Other\", false},",
                "            {\"ROOMONLY\", \"Room Only\",              \"None\",  true}",
                "        },",
                "        {\"PackageCode\", \"PackageDescription\", \"PackageCategory\", \"IsRoomOnly\"}",
                "    ),",
                "    SetTypes = Table.TransformColumnTypes(",
                "        Source,",
                "        {",
                "            {\"PackageCode\",        type text},",
                "            {\"PackageDescription\", type text},",
                "            {\"PackageCategory\",    type text},",
                "            {\"IsRoomOnly\",         type logical}",
                "        }",
                "    )",
                "in",
                "    SetTypes"
              ]
            }
          }
        ],
