        "partitions": [
          {
            "name": "Dim_SalesOwner",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    FactTable = Fact_ProfileProduction,",
                "",
                "    // Get all distinct combinations of owner-related columns from the fact table",
                "    SelectOwnerCols = Table.SelectColumns(",
                "        FactTable,",
                "        {\"Owner\", \"SegmentCode\", \"BusinessSegment\"},",
                "        MissingField.Ignore",
                "    ),",
                "",
                "    DistinctOwners = Table.Distinct(SelectOwnerCols),",
                "",
                "    // Remove nulls and blanks",
                "    RemoveNulls = Table.SelectRows(",
                "        DistinctOwners,",
                "        each [Owner] <> null and [Owner] <> \"\"",
                "    ),",
                "",
                "    // Generate a clean owner code from initials e.g. \"John Smith\" -> \"JS001\"",
                "    AddOwnerCode = Table.AddColumn(",
                "        RemoveNulls,",
                "        \"OwnerCode\",",
                "        each",
                "            let",
                "                parts    = Text.Split(Text.Trim([Owner]), \" \"),",
                "                initials = Text.Combine(List.Transform(parts, each Text.Start(_, 1)))",
                "            in",
                "                Text.Upper(initials) & \"001\",",
                "        type text",
                "    ),",
                "",
                "    // Add IsActive flag — all owners in the fact table are considered active",
                "    AddIsActive = Table.AddColumn(",
                "        AddOwnerCode,",
                "        \"IsActive\",",
                "        each true,",
                "        type logical",
                "    ),",
                "",
                "    // Rename columns to standard dimension names",
                "    Renamed = Table.RenameColumns(",
                "        AddIsActive,",
                "        {",
                "            {\"Owner\",           \"OwnerName\"},",
                "            {\"BusinessSegment\", \"OwnerSegment\"},",
                "            {\"SegmentCode\",     \"OwnerSegmentCode\"}",
                "        },",
                "        MissingField.Ignore",
                "    ),",
                "",
                "    // Add Unassigned catch-all row for profiles with no owner",
                "    UnassignedRow = #table(",
                "        {\"OwnerName\", \"OwnerSegmentCode\", \"OwnerSegment\", \"OwnerCode\", \"IsActive\"},",
                "        {{\"Unassigned\", \"UNK\", \"Unknown\", \"UNK\", false}}",
                "    ),",
                "",
                "    Combined = Table.Combine({Renamed, UnassignedRow}),",
                "",
                "    // Set types",
                "    WithTypes = Table.TransformColumnTypes(",
                "        Combined,",
                "        {",
                "            {\"OwnerName\",        type text},",
                "            {\"OwnerCode\",        type text},",
                "            {\"OwnerSegment\",     type text},",
                "            {\"OwnerSegmentCode\", type text},",
                "            {\"IsActive\",         type logical}",
                "        }",
                "    ),",
                "",
                "    // Reorder columns cleanly",
                "    ReorderCols = Table.SelectColumns(",
                "        WithTypes,",
                "        {\"OwnerCode\", \"OwnerName\", \"OwnerSegment\", \"OwnerSegmentCode\", \"IsActive\"},",
                "        MissingField.Ignore",
                "    ),",
                "",
                "    SortFinal = Table.Sort(ReorderCols, {{\"OwnerName\", Order.Ascending}})",
                "",
                "in",
                "    SortFinal"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      }
    ],
