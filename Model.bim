        "partitions": [
          {
            "name": "Fact_SegmentStats",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Folder.Files(FolderPath_Segments),",
                "",
                "    ExcelFilesOnly = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower(Text.End([Name], 5)) = \".xlsx\"",
                "    ),",
                "",
                "    ProcessFile = (fileContent as binary) as table =>",
                "        let",
                "            Workbook = Excel.Workbook(fileContent, true, true),",
                "",
                "            Sheet =",
                "                let",
                "                    matching = Table.SelectRows(Workbook, each [Name] = \"Report\")",
                "                in",
                "                    if Table.RowCount(matching) > 0",
                "                    then matching{0}[Data]",
                "                    else Workbook{0}[Data],",
                "",
                "            Skipped = Table.Skip(Sheet, 5),",
                "            Promoted = Table.PromoteHeaders(Skipped, [PromoteAllScalars = true]),",
                "",
                "            RenamedByPosition = Table.RenameColumns(",
                "                Promoted,",
                "                List.Zip({",
                "                    Table.ColumnNames(Promoted),",
                "                    {\"MarketSegment\", \"SegmentGroup\",",
                "                     \"RN_Jan\", \"RN_Feb\", \"RN_Mar\", \"RN_Apr\",",
                "                     \"RN_May\", \"RN_Jun\", \"RN_Jul\", \"RN_Aug\",",
                "                     \"RN_Sep\", \"RN_Oct\", \"RN_Nov\", \"RN_Dec\",",
                "                     \"TotalRoomNights\", \"TotalRevenue\", \"ADR\", \"RevenueMixPct\"}",
                "                })",
                "            ),",
                "",
                "            CleanedRows = Table.SelectRows(",
                "                RenamedByPosition,",
                "                each [MarketSegment] <> null",
                "                     and [MarketSegment] <> \"\"",
                "                     and [MarketSegment] <> \"GRAND TOTAL\"",
                "                     and [MarketSegment] <> \"*** End of Report ***\"",
                "            ),",
                "",
                "            WithTypes = Table.TransformColumnTypes(",
                "                CleanedRows,",
                "                {",
                "                    {\"TotalRoomNights\", type number},",
                "                    {\"TotalRevenue\",    type number},",
                "                    {\"ADR\",             type number},",
                "                    {\"RevenueMixPct\",   type number},",
                "                    {\"RN_Jan\",  type number}, {\"RN_Feb\",  type number},",
                "                    {\"RN_Mar\",  type number}, {\"RN_Apr\",  type number},",
                "                    {\"RN_May\",  type number}, {\"RN_Jun\",  type number},",
                "                    {\"RN_Jul\",  type number}, {\"RN_Aug\",  type number},",
                "                    {\"RN_Sep\",  type number}, {\"RN_Oct\",  type number},",
                "                    {\"RN_Nov\",  type number}, {\"RN_Dec\",  type number}",
                "                }",
                "            )",
                "        in",
                "            WithTypes,",
                "",
                "    AddProcessed = Table.AddColumn(",
                "        ExcelFilesOnly,",
                "        \"Processed\",",
                "        each ProcessFile([Content])",
                "    ),",
                "",
                "    Expanded = Table.ExpandTableColumn(",
                "        AddProcessed,",
                "        \"Processed\",",
                "        {\"MarketSegment\", \"SegmentGroup\",",
                "         \"RN_Jan\", \"RN_Feb\", \"RN_Mar\", \"RN_Apr\",",
                "         \"RN_May\", \"RN_Jun\", \"RN_Jul\", \"RN_Aug\",",
                "         \"RN_Sep\", \"RN_Oct\", \"RN_Nov\", \"RN_Dec\",",
                "         \"TotalRoomNights\", \"TotalRevenue\", \"ADR\", \"RevenueMixPct\"},",
                "        {\"MarketSegment\", \"SegmentGroup\",",
                "         \"RN_Jan\", \"RN_Feb\", \"RN_Mar\", \"RN_Apr\",",
                "         \"RN_May\", \"RN_Jun\", \"RN_Jul\", \"RN_Aug\",",
                "         \"RN_Sep\", \"RN_Oct\", \"RN_Nov\", \"RN_Dec\",",
                "         \"TotalRoomNights\", \"TotalRevenue\", \"ADR\", \"RevenueMixPct\"}",
                "    ),",
                "",
                "    Unpivoted = Table.UnpivotOtherColumns(",
                "        Expanded,",
                "        {\"MarketSegment\", \"SegmentGroup\",",
                "         \"TotalRoomNights\", \"TotalRevenue\", \"ADR\", \"RevenueMixPct\"},",
                "        \"MonthCol\", \"RoomNights\"",
                "    ),",
                "",
                "    AddMonthNum = Table.AddColumn(",
                "        Unpivoted,",
                "        \"MonthNum\",",
                "        each List.PositionOf(",
                "            {\"RN_Jan\",\"RN_Feb\",\"RN_Mar\",\"RN_Apr\",",
                "             \"RN_May\",\"RN_Jun\",\"RN_Jul\",\"RN_Aug\",",
                "             \"RN_Sep\",\"RN_Oct\",\"RN_Nov\",\"RN_Dec\"},",
                "            [MonthCol]",
                "        ) + 1,",
                "        Int64.Type",
                "    ),",
                "",
                "    FilterValidMonths = Table.SelectRows(",
                "        AddMonthNum,",
                "        each [MonthNum] > 0",
                "    ),",
                "",
                "    DropMonthCol = Table.RemoveColumns(FilterValidMonths, {\"MonthCol\"}),",
                "",
                "    AddCalcADR = Table.AddColumn(",
                "        DropMonthCol,",
                "        \"ADR_Calculated\",",
                "        each if [RoomNights] = null or [RoomNights] = 0",
                "             then null",
                "             else [TotalRevenue] / [TotalRoomNights],",
                "        type number",
                "    ),",
                "",
                "    SelectFinal = Table.SelectColumns(",
                "        AddCalcADR,",
                "        {\"MarketSegment\", \"SegmentGroup\",",
                "         \"MonthNum\", \"RoomNights\",",
                "         \"TotalRoomNights\", \"TotalRevenue\",",
                "         \"ADR\", \"ADR_Calculated\", \"RevenueMixPct\"},",
                "        MissingField.Ignore",
                "    ),",
                "",
                "    SortFinal = Table.Sort(",
                "        SelectFinal,",
                "        {{\"MarketSegment\", Order.Ascending}, {\"MonthNum\", Order.Ascending}}",
                "    ),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(SortFinal,{{\"RoomNights\", Int64.Type}, {\"TotalRevenue\", Int64.Type}, {\"TotalRoomNights\", Int64.Type}, {\"ADR\", type number}, {\"RevenueMixPct\", Percentage.Type}})",
                "",
                "in",
                "    #\"Changed Type\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
      {
        "name": "_Measures",
        "lineageTag": "53f303fc-becb-49f2-b18b-08589adba38b",
        "defaultDetailRowsDefinition": {
          "expression": [
            "// ── Reservations folder measures — rewritten with COALESCE ──",
            "",
            "var t = Model.Tables[\"_Measures\"];",
            "",
            "// Helper to upsert a measure",
            "void UpsertMeasure(string name, string expression, string folder, string formatString = null)",
            "{",
            "    Measure m;",
            "    if (t.Measures.Contains(name))",
            "    {",
            "        m = t.Measures[name];",
            "    }",
            "    else",
            "    {",
            "        m = t.AddMeasure(name);",
            "    }",
            "    m.Expression     = expression;",
            "    m.DisplayFolder  = folder;",
            "    if (formatString != null) m.FormatString = formatString;",
            "}",
            "",
            "// ── Total Reservations ──",
            "UpsertMeasure(",
            "    \"Total Reservations\",",
            "    @\"COALESCE(COUNTROWS(Fact_Reservations), 0)\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── New Bookings Today ──",
            "UpsertMeasure(",
            "    \"New Bookings Today\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
            "        DimDate[Date] = TODAY()",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── New Bookings Yesterday ──",
            "UpsertMeasure(",
            "    \"New Bookings Yesterday\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
            "        DimDate[Date] = TODAY() - 1",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── New Bookings Last 7 Days ──",
            "UpsertMeasure(",
            "    \"New Bookings Last 7 Days\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
            "        DimDate[Date] >= TODAY() - 7,",
            "        DimDate[Date] <= TODAY()",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── New Bookings Last 30 Days ──",
            "UpsertMeasure(",
            "    \"New Bookings Last 30 Days\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
            "        DimDate[Date] >= TODAY() - 30,",
            "        DimDate[Date] <= TODAY()",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Cancellations Last 7 Days ──",
            "UpsertMeasure(",
            "    \"Cancellations Last 7 Days\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        Fact_Reservations[ReservationStatus] = \"\"Cancelled\"\",",
            "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date]),",
            "        DimDate[Date] >= TODAY() - 7,",
            "        DimDate[Date] <= TODAY()",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Net Bookings Last 7 Days ──",
            "UpsertMeasure(",
            "    \"Net Bookings Last 7 Days\",",
            "    @\"[New Bookings Last 7 Days] - [Cancellations Last 7 Days]\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Arrivals Next 7 Days ──",
            "UpsertMeasure(",
            "    \"Arrivals Next 7 Days\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        Fact_Reservations[ReservationStatus] = \"\"Reserved\"\",",
            "        Fact_Reservations[ArrivalDate] >= TODAY(),",
            "        Fact_Reservations[ArrivalDate] <= TODAY() + 7",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Arrivals Next 30 Days ──",
            "UpsertMeasure(",
            "    \"Arrivals Next 30 Days\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        Fact_Reservations[ReservationStatus] = \"\"Reserved\"\",",
            "        Fact_Reservations[ArrivalDate] >= TODAY(),",
            "        Fact_Reservations[ArrivalDate] <= TODAY() + 30",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Nights on Books ──",
            "UpsertMeasure(",
            "    \"Nights on Books\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        SUM(Fact_Reservations[Nights]),",
            "        Fact_Reservations[ReservationStatus] = \"\"Reserved\"\"",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Revenue on Books ──",
            "UpsertMeasure(",
            "    \"Revenue on Books\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        SUM(Fact_Reservations[TotalRateRevenue]),",
            "        Fact_Reservations[ReservationStatus] = \"\"Reserved\"\"",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"\\\"€\\\"\\\\ #,0;-\\\"€\\\"\\\\ #,0;\\\"€\\\"\\\\ #,0\"",
            ");",
            "",
            "// ── Avg Rate on Books — blank on no data ──",
            "UpsertMeasure(",
            "    \"Avg Rate on Books\",",
            "    @\"DIVIDE(",
            "    [Revenue on Books],",
            "    [Nights on Books],",
            "    BLANK()",
            ")\",",
            "    \"Reservations\",",
            "    \"\\\"€\\\"\\\\ #,0.00;-\\\"€\\\"\\\\ #,0.00;\\\"€\\\"\\\\ #,0.00\"",
            ");",
            "",
            "// ── Bookings per Day 30D ──",
            "UpsertMeasure(",
            "    \"Bookings per Day 30D\",",
            "    @\"DIVIDE([New Bookings Last 30 Days], 30, 0)\",",
            "    \"Reservations\",",
            "    \"0.0\"",
            ");",
            "",
            "// ── No Show Count ──",
            "UpsertMeasure(",
            "    \"No Show Count\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        Fact_Reservations[ReservationStatus] = \"\"No Show\"\"",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── No Show Rate % — blank when no reservations ──",
            "UpsertMeasure(",
            "    \"No Show Rate %\",",
            "    @\"IF(",
            "    [Total Reservations] = 0,",
            "    BLANK(),",
            "    DIVIDE([No Show Count], [Total Reservations], BLANK())",
            ")\",",
            "    \"Reservations\",",
            "    \"0.0%;-0.0%;0.0%\"",
            ");",
            "",
            "// ── Bookings by Date — for pace chart ──",
            "UpsertMeasure(",
            "    \"Bookings by Date\",",
            "    @\"COALESCE(",
            "    CALCULATE(",
            "        COUNTROWS(Fact_Reservations),",
            "        USERELATIONSHIP(Fact_Reservations[BookingDate], DimDate[Date])",
            "    ),",
            "    0",
            ")\",",
            "    \"Reservations\",",
            "    \"0\"",
            ");",
            "",
            "// ── Today Label ──",
            "UpsertMeasure(",
            "    \"Today Label\",",
            "    @\"\\\"Business Date: \\\"\" & FORMAT(TODAY(), \"\"DD MMM YYYY\"\")\",",
            "    \"Report Config\"",
            ");",
            "",
            "// ── Page Title Sales Daily ──",
            "UpsertMeasure(",
            "    \"Page Title Sales Daily\",",
            "    @\"VAR HotelName =",
            "    CALCULATE(",
            "        LOOKUPVALUE(Params[Value], Params[Parameter], \"\"HotelName\"\"),",
            "        ALL(Params)",
            "    )",
            "RETURN",
            "IF(ISBLANK(HotelName), \"\"Hotel Name\"\", HotelName) & \"\"  |  Sales Daily\"\"\",",
            "    \"Report Config\"",
            ");",
            "",
            "Info(\"Done — \" + t.Measures.Count + \" measures in _Measures table.\");"
          ]
        },
        "partitions": [
          {
            "name": "_Measures",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i44FAA==\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Column1\", type text}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type\",{\"Column1\"})",
                "in",
                "    #\"Removed Columns\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Occupancy %",
            "expression": [
              "",
              "DIVIDE(",
              "    SUM(Fact_DailyFlash[RoomsOccupied]),",
              "    SUM(Fact_DailyFlash[RoomsAvailable])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Daily Flash",
            "lineageTag": "4f694f8a-df3f-485c-878f-013f0c6d2c00",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "ADR",
            "expression": [
              "",
              "DIVIDE(",
              "    SUM(Fact_DailyFlash[RoomRevenue]),",
              "    SUM(Fact_DailyFlash[RoomsOccupied])",
              ")"
