            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Daily Flash",
            "lineageTag": "436763e3-59c7-4b6e-9664-341d5cbe07af",
            "changedProperties": [
