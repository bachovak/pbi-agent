        "partitions": [
          {
            "name": "Fact_ProfileProduction",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Folder.Files(FolderPath_ProfileProduction),",
                "",
                "    XmlFilesOnly = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower(Text.End([Name], 4)) = \".xml\"",
                "    ),",
                "",
                "    ProcessFile = (fileContent as binary) as table =>",
                "        let",
                "            XmlDoc = Xml.Document(fileContent),",
                "            RootChildren = XmlDoc{0}[Value],",
                "",
                "            HeaderChildren = RootChildren{[Name=\"ReportHeader\"]}[Value],",
                "",
                "            GetHeader = (fieldName as text) as text =>",
                "                let",
                "                    row = Table.SelectRows(HeaderChildren, each [Name] = fieldName)",
                "                in",
                "                    if Table.RowCount(row) > 0",
                "                    then Text.From(row{0}[Value])",
                "                    else null,",
                "",
                "            DateFrom = try fnParseOperaDate(Text.Trim(GetHeader(\"DateFrom\")), DateFormat) otherwise null,",
                "            DateTo   = try fnParseOperaDate(Text.Trim(GetHeader(\"DateTo\")),   DateFormat) otherwise null,",
                "            RunDate  = try fnParseOperaDate(Text.Trim(GetHeader(\"RunDate\")),  DateFormat) otherwise null,",
                "            Currency = try GetHeader(\"Currency\") otherwise \"EUR\",",
                "",
                "            ProfilesChildren = RootChildren{[Name=\"Profiles\"]}[Value],",
                "",
                "            ProfileRecords = Table.FromRecords(",
                "                Table.TransformRows(",
                "                    ProfilesChildren,",
                "                    each",
                "                        let",
                "                            fields = [Value],",
                "                            Get = (fieldName as text) as any =>",
                "                                let",
                "                                    match = Table.SelectRows(",
                "                                        fields,",
                "                                        (row) => row[Name] = fieldName",
                "                                    )",
                "                                in",
                "                                    if Table.RowCount(match) > 0",
                "                                    then match{0}[Value]",
                "                                    else null",
                "                        in [",
                "                            ProfileName           = Get(\"ProfileName\"),",
                "                            ProfileType           = Get(\"ProfileType\"),",
                "                            BusinessSegment       = Get(\"BusinessSegment\"),",
                "                            SegmentCode           = Get(\"SegmentCode\"),",
                "                            Owner                 = Get(\"Owner\"),",
                "                            Country               = Get(\"Country\"),",
                "                            RoomNights            = Get(\"RoomNights\"),",
                "                            CancelledRooms        = Get(\"CancelledRooms\"),",
                "                            NoShowRooms           = Get(\"NoShowRooms\"),",
                "                            DayUseRooms           = Get(\"DayUseRooms\"),",
                "                            ADR                   = Get(\"ADR\"),",
                "                            RoomRevenue           = Get(\"RoomRevenue\"),",
                "                            FBRevenue             = Get(\"FBRevenue\"),",
                "                            ExtraRevenue          = Get(\"ExtraRevenue\"),",
                "                            NonRevenue            = Get(\"NonRevenue\"),",
                "                            TotalRevenue          = Get(\"TotalRevenue\"),",
                "                            Adults                = Get(\"Adults\"),",
                "                            TotalRevPerGuest      = Get(\"TotalRevPerGuest\"),",
                "                            RoomRevPerGuest       = Get(\"RoomRevPerGuest\"),",
                "                            FBRevPerGuest         = Get(\"FBRevPerGuest\"),",
                "                            ReservationNights     = Get(\"ReservationNights\"),",
                "                            ReservationArrivals   = Get(\"ReservationArrivals\"),",
                "                            CancelledReservations = Get(\"CancelledReservations\"),",
                "                            NoShowReservations    = Get(\"NoShowReservations\"),",
                "                            DayUseReservations    = Get(\"DayUseReservations\"),",
                "                            BlockRoomNights       = Get(\"BlockRoomNights\"),",
                "                            BlockRoomRevenue      = Get(\"BlockRoomRevenue\"),",
                "                            BlockADR              = Get(\"BlockADR\"),",
                "                            IndividualRoomNights  = Get(\"IndividualRoomNights\"),",
                "                            IndividualRoomRevenue = Get(\"IndividualRoomRevenue\"),",
                "                            IndividualADR         = Get(\"IndividualADR\"),",
                "                            AvgLengthOfStay       = Get(\"AvgLengthOfStay\")",
                "                        ]",
                "                )",
                "            ),",
                "",
                "            WithDates = Table.AddColumn(",
                "                Table.AddColumn(",
                "                    Table.AddColumn(ProfileRecords,",
                "                        \"ReportDateFrom\", each DateFrom, type date),",
                "                    \"ReportDateTo\", each DateTo, type date),",
                "                \"RunDate\", each RunDate, type date),",
                "",
                "            WithCurrency = Table.AddColumn(",
                "                WithDates, \"Currency\", each Currency, type text),",
                "",
                "            WithTypes = Table.TransformColumnTypes(",
                "                WithCurrency,",
                "                {",
                "                    {\"RoomNights\",            Int64.Type},",
                "                    {\"CancelledRooms\",        Int64.Type},",
                "                    {\"NoShowRooms\",           Int64.Type},",
                "                    {\"DayUseRooms\",           Int64.Type},",
                "                    {\"Adults\",                Int64.Type},",
                "                    {\"ReservationNights\",     Int64.Type},",
                "                    {\"ReservationArrivals\",   Int64.Type},",
                "                    {\"CancelledReservations\", Int64.Type},",
                "                    {\"NoShowReservations\",    Int64.Type},",
                "                    {\"DayUseReservations\",    Int64.Type},",
                "                    {\"BlockRoomNights\",       Int64.Type},",
                "                    {\"IndividualRoomNights\",  Int64.Type},",
                "                    {\"ADR\",                   type number},",
                "                    {\"RoomRevenue\",           type number},",
                "                    {\"FBRevenue\",             type number},",
                "                    {\"ExtraRevenue\",          type number},",
                "                    {\"NonRevenue\",            type number},",
                "                    {\"TotalRevenue\",          type number},",
                "                    {\"TotalRevPerGuest\",      type number},",
                "                    {\"RoomRevPerGuest\",       type number},",
                "                    {\"FBRevPerGuest\",         type number},",
                "                    {\"BlockRoomRevenue\",      type number},",
                "                    {\"BlockADR\",              type number},",
                "                    {\"IndividualRoomRevenue\", type number},",
                "                    {\"IndividualADR\",         type number},",
                "                    {\"AvgLengthOfStay\",       type number},",
                "                    {\"ProfileName\",           type text},",
                "                    {\"ProfileType\",           type text},",
                "                    {\"BusinessSegment\",       type text},",
                "                    {\"SegmentCode\",           type text},",
                "                    {\"Owner\",                 type text},",
                "                    {\"Country\",               type text},",
                "                    {\"Currency\",              type text}",
                "                }",
                "            ),",
                "",
                "            WithCancelRate = Table.AddColumn(",
                "                WithTypes,",
                "                \"CancellationRate\",",
                "                each",
                "                    if [ReservationArrivals] = null or [ReservationArrivals] = 0",
                "                    then null",
                "                    else [CancelledReservations] /",
                "                         ([ReservationArrivals] + [CancelledReservations]),",
                "                type number",
                "            )",
                "        in",
                "            WithCancelRate,",
                "",
                "    AddProcessed = Table.AddColumn(",
                "        XmlFilesOnly,",
                "        \"Processed\",",
                "        each ProcessFile([Content])",
                "    ),",
                "",
                "    Expanded = Table.ExpandTableColumn(",
                "        AddProcessed,",
                "        \"Processed\",",
                "        {",
                "            \"ProfileName\",\"ProfileType\",\"BusinessSegment\",\"SegmentCode\",",
                "            \"Owner\",\"Country\",\"RoomNights\",\"CancelledRooms\",\"NoShowRooms\",",
                "            \"DayUseRooms\",\"ADR\",\"RoomRevenue\",\"FBRevenue\",\"ExtraRevenue\",",
                "            \"NonRevenue\",\"TotalRevenue\",\"Adults\",\"TotalRevPerGuest\",",
                "            \"RoomRevPerGuest\",\"FBRevPerGuest\",\"ReservationNights\",",
                "            \"ReservationArrivals\",\"CancelledReservations\",\"NoShowReservations\",",
                "            \"DayUseReservations\",\"BlockRoomNights\",\"BlockRoomRevenue\",\"BlockADR\",",
                "            \"IndividualRoomNights\",\"IndividualRoomRevenue\",\"IndividualADR\",",
                "            \"AvgLengthOfStay\",\"ReportDateFrom\",\"ReportDateTo\",\"RunDate\",",
                "            \"Currency\",\"CancellationRate\"",
                "        },",
                "        {",
                "            \"ProfileName\",\"ProfileType\",\"BusinessSegment\",\"SegmentCode\",",
                "            \"Owner\",\"Country\",\"RoomNights\",\"CancelledRooms\",\"NoShowRooms\",",
                "            \"DayUseRooms\",\"ADR\",\"RoomRevenue\",\"FBRevenue\",\"ExtraRevenue\",",
                "            \"NonRevenue\",\"TotalRevenue\",\"Adults\",\"TotalRevPerGuest\",",
                "            \"RoomRevPerGuest\",\"FBRevPerGuest\",\"ReservationNights\",",
                "            \"ReservationArrivals\",\"CancelledReservations\",\"NoShowReservations\",",
                "            \"DayUseReservations\",\"BlockRoomNights\",\"BlockRoomRevenue\",\"BlockADR\",",
                "            \"IndividualRoomNights\",\"IndividualRoomRevenue\",\"IndividualADR\",",
                "            \"AvgLengthOfStay\",\"ReportDateFrom\",\"ReportDateTo\",\"RunDate\",",
                "            \"Currency\",\"CancellationRate\"",
                "        }",
                "    ),",
                "",
                "    SelectFinal = Table.SelectColumns(",
                "        Expanded,",
                "        {",
                "            \"ProfileName\",\"ProfileType\",\"BusinessSegment\",\"SegmentCode\",",
                "            \"Owner\",\"Country\",\"RoomNights\",\"CancelledRooms\",\"NoShowRooms\",",
                "            \"DayUseRooms\",\"ADR\",\"RoomRevenue\",\"FBRevenue\",\"ExtraRevenue\",",
                "            \"NonRevenue\",\"TotalRevenue\",\"Adults\",\"TotalRevPerGuest\",",
                "            \"RoomRevPerGuest\",\"FBRevPerGuest\",\"ReservationNights\",",
                "            \"ReservationArrivals\",\"CancelledReservations\",\"NoShowReservations\",",
                "            \"DayUseReservations\",\"BlockRoomNights\",\"BlockRoomRevenue\",\"BlockADR\",",
                "            \"IndividualRoomNights\",\"IndividualRoomRevenue\",\"IndividualADR\",",
                "            \"AvgLengthOfStay\",\"ReportDateFrom\",\"ReportDateTo\",\"RunDate\",",
                "            \"Currency\",\"CancellationRate\"",
                "        },",
                "        MissingField.Ignore",
                "    ),",
                "",
                "    SortFinal = Table.Sort(",
                "        SelectFinal,",
                "        {{\"RoomNights\", Order.Descending}}",
                "    ),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(SortFinal,{{\"RoomNights\", Int64.Type}, {\"CancelledRooms\", Int64.Type}, {\"NoShowRooms\", Int64.Type}, {\"DayUseRooms\", Int64.Type}, {\"ADR\", Currency.Type}, {\"RoomRevenue\", Currency.Type}, {\"FBRevenue\", Currency.Type}, {\"ExtraRevenue\", Currency.Type}, {\"NonRevenue\", Currency.Type}, {\"TotalRevenue\", Currency.Type}, {\"Adults\", Int64.Type}, {\"TotalRevPerGuest\", Currency.Type}, {\"RoomRevPerGuest\", Currency.Type}, {\"FBRevPerGuest\", Currency.Type}, {\"ReservationNights\", Int64.Type}, {\"ReservationArrivals\", Int64.Type}, {\"CancelledReservations\", Int64.Type}, {\"NoShowReservations\", Int64.Type}, {\"DayUseReservations\", Int64.Type}, {\"BlockRoomNights\", Int64.Type}, {\"BlockRoomRevenue\", Currency.Type}, {\"BlockADR\", Currency.Type}, {\"IndividualRoomNights\", Int64.Type}, {\"IndividualRoomRevenue\", Currency.Type}, {\"IndividualADR\", Currency.Type}, {\"AvgLengthOfStay\", type number}, {\"ReportDateFrom\", type date}, {\"ReportDateTo\", type date}, {\"RunDate\", type date}, {\"CancellationRate\", type number}})",
                "",
                "in",
                "    #\"Changed Type\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
