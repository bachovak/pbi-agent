          },
          {
            "name": "Forecast Avg Package Rate",
            "expression": [
              "",
              "DIVIDE(",
              "    [Forecast Total Value],",
              "    [Forecast Rooms]",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Package Forecast",
            "lineageTag": "2973d1f3-10d7-40bd-b043-5949d96b0613"
          },
          {
            "name": "Forecast Avg Uplift",
            "expression": [
              "",
              "AVERAGE(Fact_PackageForecast[PackageUplift])"
            ],
            "formatString": "0",
            "displayFolder": "Package Forecast",
            "lineageTag": "e5f3ba04-ed3f-4ee4-aae0-08b0593731df"
          },
          {
            "name": "Forecast Occupancy %",
            "expression": [
              "",
              "DIVIDE(",
              "    [Forecast Rooms],",
              "    [_TotalRooms]",
              ")"
            ],
            "displayFolder": "Package Forecast",
            "lineageTag": "d252d438-1ad9-4007-818b-78ed9004875d",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "FB Cover Ratio",
            "expression": [
              "",
              "// F&B covers as a % of rooms — key for kitchen planning",
              "DIVIDE(",
              "    [Forecast Pax Covers],",
              "    [Forecast Rooms]",
              ")"
            ],
            "displayFolder": "Package Forecast",
            "lineageTag": "5b53edbe-5c37-48cb-b70d-db20a97ca361",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "_3 Page Title",
            "expression": [
              "",
              "VAR HotelName = LOOKUPVALUE(Params[Value], Params[Parameter], \"HotelName\")",
              "RETURN",
              "HotelName & \"  |  8-Day Package Forecast\""
            ],
            "displayFolder": "Report Config",
            "lineageTag": "e70e219a-4941-4fb5-a466-385530f25cfd",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Package Revenue Mix %",
            "expression": [
              "",
              "// Package revenue as % of total — shows dependency on packages",
              "DIVIDE(",
              "    [Forecast Package Revenue],",
              "    [Forecast Total Value]",
              ")"
            ],
            "displayFolder": "Package Forecast",
            "lineageTag": "c1b1e4ca-9900-4af5-8475-4a1e4c26ba96",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Room Only %",
            "expression": [
              "",
              "// Room only rooms as % of total — shows how many guests have no F&B commitment",
              "DIVIDE(",
              "    CALCULATE(",
              "        [Forecast Rooms],",
              "        Dim_PackageCode[IsRoomOnly] = TRUE()",
              "    ),",
              "    [Forecast Rooms]",
              ")"
            ],
            "displayFolder": "Package Forecast",
            "lineageTag": "0364add1-3bcf-4fd3-ab54-93bc6b6861d2",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Tooltip Package Room Mix %",
            "expression": [
              "",
              "DIVIDE(",
              "    [Forecast Rooms],",
              "    CALCULATE([Forecast Rooms], ALL(Dim_PackageCode))",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Package Forecast\\Tooltips",
            "lineageTag": "954a5521-8636-427f-8553-8809b1c70931"
          },
          {
            "name": "Tooltip Package Revenue Mix %",
            "expression": [
              "",
              "DIVIDE(",
              "    [Forecast Total Value],",
              "    CALCULATE([Forecast Total Value], ALL(Dim_PackageCode))",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Package Forecast\\Tooltips",
            "lineageTag": "1032eb4d-de81-4688-948d-3152edf58596"
          },
          {
            "name": "Tooltip Revenue per Room",
            "expression": [
              "",
              "DIVIDE(",
              "    [Forecast Total Value],",
              "    [Forecast Rooms]",
              ")"
            ],
            "formatString": "\"€\"\\ #,0.00;-\"€\"\\ #,0.00;\"€\"\\ #,0.00",
            "displayFolder": "Package Forecast\\Tooltips",
            "lineageTag": "9866c290-280e-4963-a79f-03a82ce96c1c"
          },
          {
            "name": "Tooltip Revenue Premium",
            "expression": [
              "",
              "[Tooltip Package Revenue Mix %] - [Tooltip Package Room Mix %]"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "Package Forecast\\Tooltips",
            "lineageTag": "d8701cf8-366c-4054-8f0d-b602d9a0ab60"
          },
          {
            "name": "Profile Room Nights",
