        "partitions": [
          {
            "name": "Fact_DailyFlash",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    // ── Step 1: Load XML files from the Flash folder ──",
                "    Source = Folder.Files(FolderPath_Flash),",
                "",
                "    XmlFilesOnly = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower(Text.End([Name], 4)) = \".xml\"",
                "    ),",
                "",
                "    // ── Step 2: Process each file ──",
                "    ProcessFile = (fileContent as binary) as table =>",
                "        let",
                "            XmlDoc      = Xml.Document(fileContent),",
                "            RootChildren = XmlDoc{0}[Value],",
                "",
                "            // ── Header navigation ──",
                "            HeaderRows  = RootChildren{[Name = \"ReportHeader\"]}[Value],",
                "",
                "            GetHeader = (fieldName as text) as any =>",
                "                let",
                "                    raw = Table.SelectRows(HeaderRows, each [Name] = fieldName)",
                "                in",
                "                    if Table.RowCount(raw) > 0",
                "                    then",
                "                        let v = raw{0}[Value]",
                "                        in if v is table or v is list or v is record then null else v",
                "                    else null,",
                "",
                "            BusinessDate = try fnParseOperaDate(",
                "                               Text.Trim(Text.From(GetHeader(\"BusinessDate\"))),",
                "                               DateFormat",
                "                           ) otherwise null,",
                "",
                "            // ── Statistics section navigation ──",
                "            StatsRows    = RootChildren{[Name = \"Statistics\"]}[Value],",
                "",
                "            GetSection = (sectionName as text) as table =>",
                "                let",
                "                    match = Table.SelectRows(StatsRows, each [Name] = sectionName)",
                "                in",
                "                    if Table.RowCount(match) > 0",
                "                    then match{0}[Value]",
                "                    else #table({\"Name\",\"Value\"}, {}),",
                "",
                "            RoomsSection   = GetSection(\"Rooms\"),",
                "            RevenueSection = GetSection(\"Revenue\"),",
                "            KPISection     = GetSection(\"KPIs\"),",
                "",
                "            // ── Field extractor — handles empty XML tags safely ──",
                "            GetField = (sectionTable as table, fieldName as text) as any =>",
                "                let",
                "                    match = Table.SelectRows(sectionTable, each [Name] = fieldName),",
                "                    raw   = if Table.RowCount(match) > 0",
                "                            then match{0}[Value]",
                "                            else null",
                "                in",
                "                    if raw = null           then null",
                "                    else if raw is table    then null",
                "                    else if raw is list     then null",
                "                    else if raw is record   then null",
                "                    else raw,",
                "",
                "            // ── Extract all fields ──",
                "            RoomsAvailable  = fnCleanNumeric(GetField(RoomsSection, \"AvailableRooms\")),",
                "            RoomsOccupied   = fnCleanNumeric(GetField(RoomsSection, \"RoomsOccupied\")),",
                "            RoomsOOO        = fnCleanNumeric(GetField(RoomsSection, \"RoomsOutOfOrder\")),",
                "            RoomsComp       = fnCleanNumeric(GetField(RoomsSection, \"ComplimentaryRooms\")),",
                "            RoomsHouseUse   = fnCleanNumeric(GetField(RoomsSection, \"HouseUseRooms\")),",
                "",
                "            RoomRevenue     = fnCleanNumeric(GetField(RevenueSection, \"RoomRevenue\")),",
                "            FBRevenue       = fnCleanNumeric(GetField(RevenueSection, \"FoodAndBeverageRevenue\")),",
                "            OtherRevenue    = fnCleanNumeric(GetField(RevenueSection, \"OtherRevenue\")),",
                "            TotalRevenue    = fnCleanNumeric(GetField(RevenueSection, \"TotalRevenue\")),",
                "",
                "            // ── Recalculate KPIs from source numbers (same as current query) ──",
                "            OccupancyPct    =",
                "                let avail = if RoomsAvailable = null or RoomsAvailable = 0",
                "                            then TotalRooms else RoomsAvailable,",
                "                    occ   = if RoomsOccupied = null then 0 else RoomsOccupied",
                "                in  if avail = 0 then null else occ / avail,",
                "",
                "            ADR             =",
                "                let rev = if RoomRevenue = null then 0 else RoomRevenue,",
                "                    occ = if RoomsOccupied = null or RoomsOccupied = 0 then null else RoomsOccupied",
                "                in  if occ = null then null else rev / occ,",
                "",
                "            RevPAR          =",
                "                let rev   = if RoomRevenue = null then 0 else RoomRevenue,",
                "                    avail = if RoomsAvailable = null or RoomsAvailable = 0",
                "                            then TotalRooms else RoomsAvailable",
                "                in  if avail = 0 then null else rev / avail,",
                "",
                "            // ── Build one-row result ──",
                "            Result = #table(",
                "                {",
                "                    \"Date\", \"FileDate\",",
                "                    \"RoomsAvailable\", \"RoomsOccupied\", \"RoomsOOO\",",
                "                    \"RoomsComp\", \"RoomsHouseUse\",",
                "                    \"RoomRevenue\", \"FBRevenue\", \"OtherRevenue\", \"TotalRevenue\",",
                "                    \"OccupancyPct\", \"ADR\", \"RevPAR\"",
                "                },",
                "                {{",
                "                    BusinessDate,   BusinessDate,",
                "                    RoomsAvailable, RoomsOccupied, RoomsOOO,",
                "                    RoomsComp,      RoomsHouseUse,",
                "                    RoomRevenue,    FBRevenue,    OtherRevenue, TotalRevenue,",
                "                    OccupancyPct,   ADR,          RevPAR",
                "                }}",
                "            )",
                "        in",
                "            Result,",
                "",
                "    // ── Step 3: Apply to all files and combine ──",
                "    AddProcessed = Table.AddColumn(",
                "        XmlFilesOnly,",
                "        \"Processed\",",
                "        each ProcessFile([Content])",
                "    ),",
                "",
                "    Expanded = Table.ExpandTableColumn(",
                "        AddProcessed,",
                "        \"Processed\",",
                "        {",
                "            \"Date\", \"FileDate\",",
                "            \"RoomsAvailable\", \"RoomsOccupied\", \"RoomsOOO\",",
                "            \"RoomsComp\", \"RoomsHouseUse\",",
                "            \"RoomRevenue\", \"FBRevenue\", \"OtherRevenue\", \"TotalRevenue\",",
                "            \"OccupancyPct\", \"ADR\", \"RevPAR\"",
                "        }",
                "    ),",
                "",
                "    // ── Step 4: Set types ──",
                "    WithTypes = Table.TransformColumnTypes(",
                "        Expanded,",
                "        {",
                "            {\"Date\",           type date},",
                "            {\"FileDate\",       type date},",
                "            {\"RoomsAvailable\", type number},",
                "            {\"RoomsOccupied\",  type number},",
                "            {\"RoomsOOO\",       type number},",
                "            {\"RoomsComp\",      type number},",
                "            {\"RoomsHouseUse\",  type number},",
                "            {\"RoomRevenue\",    type number},",
                "            {\"FBRevenue\",      type number},",
                "            {\"OtherRevenue\",   type number},",
                "            {\"TotalRevenue\",   type number},",
                "            {\"OccupancyPct\",   type number},",
                "            {\"ADR\",            type number},",
                "            {\"RevPAR\",         type number}",
                "        }",
                "    ),",
                "",
                "    // ── Step 5: Deduplicate and sort ──",
                "    // One file per business date — keep latest FileDate if duplicates exist",
                "    Grouped = Table.Group(",
                "        WithTypes,",
                "        {\"Date\"},",
                "        {{\"LatestRow\", each (Table.Sort(_, {{\"FileDate\", Order.Descending}})){0}, type record}}",
                "    ),",
                "",
                "    ExpandLatest = Table.ExpandRecordColumn(",
                "        Grouped,",
                "        \"LatestRow\",",
                "        {",
                "            \"FileDate\",",
                "            \"RoomsAvailable\", \"RoomsOccupied\", \"RoomsOOO\",",
                "            \"RoomsComp\", \"RoomsHouseUse\",",
                "            \"RoomRevenue\", \"FBRevenue\", \"OtherRevenue\", \"TotalRevenue\",",
                "            \"OccupancyPct\", \"ADR\", \"RevPAR\"",
                "        }",
                "    ),",
                "",
                "    // Re-apply types after expand (expand strips them)",
                "    FinalTypes = Table.TransformColumnTypes(",
                "        ExpandLatest,",
                "        {",
                "            {\"Date\",           type date},",
                "            {\"FileDate\",       type date},",
                "            {\"RoomsAvailable\", type number},",
                "            {\"RoomsOccupied\",  type number},",
                "            {\"RoomsOOO\",       type number},",
                "            {\"RoomsComp\",      type number},",
                "            {\"RoomsHouseUse\",  type number},",
                "            {\"RoomRevenue\",    type number},",
                "            {\"FBRevenue\",      type number},",
                "            {\"OtherRevenue\",   type number},",
                "            {\"TotalRevenue\",   type number},",
                "            {\"OccupancyPct\",   type number},",
                "            {\"ADR\",            type number},",
                "            {\"RevPAR\",         type number}",
                "        }",
                "    ),",
                "",
                "    SortByDate = Table.Sort(FinalTypes, {{\"Date\", Order.Ascending}}),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(SortByDate,{{\"RoomsAvailable\", Int64.Type}, {\"RoomsOccupied\", Int64.Type}, {\"RoomsOOO\", Int64.Type}, {\"RoomsComp\", Int64.Type}, {\"RoomsHouseUse\", Int64.Type}, {\"RoomRevenue\", Currency.Type}, {\"FBRevenue\", Currency.Type}, {\"OtherRevenue\", Currency.Type}, {\"TotalRevenue\", Currency.Type}, {\"OccupancyPct\", Percentage.Type}, {\"ADR\", Currency.Type}, {\"RevPAR\", Currency.Type}})",
                "",
                "in",
                "    #\"Changed Type\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Measure",
            "lineageTag": "96d84296-7868-4c69-b079-b2132ee99ef0",
            "annotations": [
              {
                "name": "43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c",
                "value": "True"
              }
            ]
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
