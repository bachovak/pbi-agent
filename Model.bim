        "partitions": [
          {
            "name": "Fact_Reservations",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    // ── Step 1: Load XML files from reservations folder ──",
                "    Source = Folder.Files(FolderPath_Reservations),",
                "",
                "    XmlFilesOnly = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower(Text.End([Name], 4)) = \".xml\"",
                "    ),",
                "",
                "    // ── Step 2: Process each file ──",
                "    ProcessFile = (fileContent as binary) as table =>",
                "        let",
                "            XmlDoc = Xml.Document(fileContent),",
                "",
                "            // Root element children — ReportHeader and Reservations",
                "            RootChildren = XmlDoc{0}[Value],",
                "",
                "            // Extract header fields",
                "            HeaderChildren = RootChildren{[Name=\"ReportHeader\"]}[Value],",
                "",
                "            GetHeader = (fieldName as text) as text =>",
                "                let",
                "                    row = Table.SelectRows(HeaderChildren, each [Name] = fieldName)",
                "                in",
                "                    if Table.RowCount(row) > 0",
                "                    then Text.From(row{0}[Value])",
                "                    else null,",
                "",
                "            RunDate    = try fnParseOperaDate(Text.Trim(GetHeader(\"RunDate\")),    DateFormat) otherwise null,",
                "            PeriodFrom = try fnParseOperaDate(Text.Trim(GetHeader(\"PeriodFrom\")), DateFormat) otherwise null,",
                "            PeriodTo   = try fnParseOperaDate(Text.Trim(GetHeader(\"PeriodTo\")),   DateFormat) otherwise null,",
                "",
                "            // Navigate to Reservations node",
                "            ReservationsChildren = RootChildren{[Name=\"Reservations\"]}[Value],",
                "",
                "            // Each row in ReservationsChildren is one <Reservation> element",
                "            // [Value] on each row is a table of that reservation's child fields",
                "            ReservationRecords = Table.FromRecords(",
                "                Table.TransformRows(",
                "                    ReservationsChildren,",
                "                    each",
                "                        let",
                "                            fields = [Value],",
                "                            Get = (fieldName as text) as any =>",
                "                                let",
                "                                    match = Table.SelectRows(",
                "                                        fields,",
                "                                        (row) => row[Name] = fieldName",
                "                                    ),",
                "                                    raw = if Table.RowCount(match) > 0",
                "                                          then match{0}[Value]",
                "                                          else null",
                "                                in",
                "                                    if raw = null then null",
                "                                    else if raw is table then null",
                "                                    else if raw is list then null",
                "                                    else if raw is record then null",
                "                                    else Text.From(raw)",
                "                        in [",
                "                            ConfirmationNumber  = Get(\"ConfirmationNumber\"),",
                "                            ReservationStatus   = Get(\"ReservationStatus\"),",
                "                            ArrivalDate_Raw     = Get(\"ArrivalDate\"),",
                "                            DepartureDate_Raw   = Get(\"DepartureDate\"),",
                "                            BookingDate_Raw     = Get(\"BookingDate\"),",
                "                            Nights_Raw          = Get(\"Nights\"),",
                "                            Adults_Raw          = Get(\"Adults\"),",
                "                            Children_Raw        = Get(\"Children\"),",
                "                            RoomType            = Get(\"RoomType\"),",
                "                            RateCode            = Get(\"RateCode\"),",
                "                            RateAmount_Raw      = Get(\"RateAmount\"),",
                "                            MarketSegment       = Get(\"MarketSegment\"),",
                "                            SourceOfBusiness    = Get(\"Source\"),",
                "                            BookingChannel      = Get(\"Channel\"),",
                "                            GuestNationality    = Get(\"Nationality\"),",
                "                            CompanyTravelAgent  = Get(\"CompanyTravelAgent\"),",
                "                            VIPCode             = Get(\"VIPCode\")",
                "                        ]",
                "                )",
                "            ),",
                "",
                "            // ── Step 3: Parse dates ──",
                "            ParseArrival = Table.AddColumn(",
                "                ReservationRecords, \"ArrivalDate\",",
                "                each try fnParseOperaDate(Text.From([ArrivalDate_Raw]), DateFormat) otherwise null,",
                "                type date",
                "            ),",
                "",
                "            ParseDeparture = Table.AddColumn(",
                "                ParseArrival, \"DepartureDate\",",
                "                each try fnParseOperaDate(Text.From([DepartureDate_Raw]), DateFormat) otherwise null,",
                "                type date",
                "            ),",
                "",
                "            ParseBooking = Table.AddColumn(",
                "                ParseDeparture, \"BookingDate\",",
                "                each try fnParseOperaDate(Text.From([BookingDate_Raw]), DateFormat) otherwise null,",
                "                type date",
                "            ),",
                "",
                "            // ── Step 4: Parse numerics ──",
                "            ParseNumerics = Table.TransformColumns(",
                "                ParseBooking,",
                "                {",
                "                    {\"Nights_Raw\",     each fnCleanNumeric(_), type number},",
                "                    {\"Adults_Raw\",     each fnCleanNumeric(_), type number},",
                "                    {\"Children_Raw\",   each fnCleanNumeric(_), type number},",
                "                    {\"RateAmount_Raw\", each fnCleanNumeric(_), type number}",
                "                }",
                "            ),",
                "",
                "            // ── Step 5: Calculated columns ──",
                "",
                "            // Lead time in days",
                "            AddLeadTime = Table.AddColumn(",
                "                ParseNumerics, \"BookingLeadDays\",",
                "                each",
                "                    if [BookingDate] = null or [ArrivalDate] = null",
                "                    then null",
                "                    else Duration.Days([ArrivalDate] - [BookingDate]),",
                "                type number",
                "            ),",
                "",
                "            // Total revenue per reservation",
                "            AddTotalRevenue = Table.AddColumn(",
                "                AddLeadTime, \"TotalRateRevenue\",",
                "                each",
                "                    let",
                "                        n = if [Nights_Raw] = null then 0 else [Nights_Raw],",
                "                        r = if [RateAmount_Raw] = null then 0 else [RateAmount_Raw]",
                "                    in",
                "                        n * r,",
                "                type number",
                "            ),",
                "",
                "            // Standardise status values",
                "            StandardiseStatus = Table.TransformColumns(",
                "                AddTotalRevenue,",
                "                {",
                "                    {\"ReservationStatus\",",
                "                     each",
                "                        if Text.Contains(Text.Upper(Text.From(_)), \"CANCEL\")    then \"Cancelled\"",
                "                        else if Text.Contains(Text.Upper(Text.From(_)), \"NO SHOW\")   then \"No Show\"",
                "                        else if Text.Contains(Text.Upper(Text.From(_)), \"IN HOUSE\")  then \"In House\"",
                "                        else if Text.Contains(Text.Upper(Text.From(_)), \"CHECKED OUT\") then \"Checked Out\"",
                "                        else if Text.Contains(Text.Upper(Text.From(_)), \"DUE IN\")    then \"Due In\"",
                "                        else if Text.Contains(Text.Upper(Text.From(_)), \"RESERVED\")  then \"Reserved\"",
                "                        else Text.From(_),",
                "                     type text}",
                "                }",
                "            ),",
                "",
                "            // Add file-level date context",
                "            WithRunDate = Table.AddColumn(",
                "                StandardiseStatus, \"FileRunDate\", each RunDate, type date",
                "            ),",
                "            WithPeriodFrom = Table.AddColumn(",
                "                WithRunDate, \"FilePeriodFrom\", each PeriodFrom, type date",
                "            ),",
                "            WithPeriodTo = Table.AddColumn(",
                "                WithPeriodFrom, \"FilePeriodTo\", each PeriodTo, type date",
                "            ),",
                "",
                "            // ── Step 6: Final column selection and rename ──",
                "            SelectFinal = Table.SelectColumns(",
                "                WithPeriodTo,",
                "                {",
                "                    \"ConfirmationNumber\",",
                "                    \"ReservationStatus\",",
                "                    \"ArrivalDate\",",
                "                    \"DepartureDate\",",
                "                    \"BookingDate\",",
                "                    \"Nights_Raw\",",
                "                    \"Adults_Raw\",",
                "                    \"Children_Raw\",",
                "                    \"RoomType\",",
                "                    \"RateCode\",",
                "                    \"RateAmount_Raw\",",
                "                    \"TotalRateRevenue\",",
                "                    \"BookingLeadDays\",",
                "                    \"MarketSegment\",",
                "                    \"SourceOfBusiness\",",
                "                    \"BookingChannel\",",
                "                    \"GuestNationality\",",
                "                    \"CompanyTravelAgent\",",
                "                    \"VIPCode\",",
                "                    \"FileRunDate\",",
                "                    \"FilePeriodFrom\",",
                "                    \"FilePeriodTo\"",
                "                },",
                "                MissingField.Ignore",
                "            ),",
                "",
                "            FinalRename = Table.RenameColumns(",
                "                SelectFinal,",
                "                {",
                "                    {\"Nights_Raw\",     \"Nights\"},",
                "                    {\"Adults_Raw\",     \"Adults\"},",
                "                    {\"Children_Raw\",   \"Children\"},",
                "                    {\"RateAmount_Raw\", \"RateAmount\"}",
                "                },",
                "                MissingField.Ignore",
                "            )",
                "        in",
                "            FinalRename,",
                "",
                "    // ── Step 7: Apply to all files and combine ──",
                "    AddProcessed = Table.AddColumn(",
                "        XmlFilesOnly,",
                "        \"Processed\",",
                "        each ProcessFile([Content])",
                "    ),",
                "",
                "    Expanded = Table.ExpandTableColumn(",
                "        AddProcessed,",
                "        \"Processed\",",
                "        {",
                "            \"ConfirmationNumber\", \"ReservationStatus\",",
                "            \"ArrivalDate\", \"DepartureDate\", \"BookingDate\",",
                "            \"Nights\", \"Adults\", \"Children\",",
                "            \"RoomType\", \"RateCode\", \"RateAmount\",",
                "            \"TotalRateRevenue\", \"BookingLeadDays\",",
                "            \"MarketSegment\", \"SourceOfBusiness\", \"BookingChannel\",",
                "            \"GuestNationality\", \"CompanyTravelAgent\", \"VIPCode\",",
                "            \"FileRunDate\", \"FilePeriodFrom\", \"FilePeriodTo\"",
                "        },",
                "        {",
                "            \"ConfirmationNumber\", \"ReservationStatus\",",
                "            \"ArrivalDate\", \"DepartureDate\", \"BookingDate\",",
                "            \"Nights\", \"Adults\", \"Children\",",
                "            \"RoomType\", \"RateCode\", \"RateAmount\",",
                "            \"TotalRateRevenue\", \"BookingLeadDays\",",
                "            \"MarketSegment\", \"SourceOfBusiness\", \"BookingChannel\",",
                "            \"GuestNationality\", \"CompanyTravelAgent\", \"VIPCode\",",
                "            \"FileRunDate\", \"FilePeriodFrom\", \"FilePeriodTo\"",
                "        }",
                "    ),",
                "",
                "    // ── Step 8: Keep only data columns, remove file metadata ──",
                "    SelectFinalCols = Table.SelectColumns(",
                "        Expanded,",
                "        {",
                "            \"ConfirmationNumber\", \"ReservationStatus\",",
                "            \"ArrivalDate\", \"DepartureDate\", \"BookingDate\",",
                "            \"Nights\", \"Adults\", \"Children\",",
                "            \"RoomType\", \"RateCode\", \"RateAmount\",",
                "            \"TotalRateRevenue\", \"BookingLeadDays\",",
                "            \"MarketSegment\", \"SourceOfBusiness\", \"BookingChannel\",",
                "            \"GuestNationality\", \"CompanyTravelAgent\", \"VIPCode\",",
                "            \"FileRunDate\", \"FilePeriodFrom\", \"FilePeriodTo\"",
                "        },",
                "        MissingField.Ignore",
                "    ),",
                "",
                "    // ── Step 9: Set final types ──",
                "    WithTypes = Table.TransformColumnTypes(",
                "        SelectFinalCols,",
                "        {",
                "            {\"ConfirmationNumber\",  type text},",
                "            {\"ReservationStatus\",   type text},",
                "            {\"ArrivalDate\",         type date},",
                "            {\"DepartureDate\",       type date},",
                "            {\"BookingDate\",         type date},",
                "            {\"Nights\",              type number},",
                "            {\"Adults\",              type number},",
                "            {\"Children\",            type number},",
                "            {\"RoomType\",            type text},",
                "            {\"RateCode\",            type text},",
                "            {\"RateAmount\",          type number},",
                "            {\"TotalRateRevenue\",    type number},",
                "            {\"BookingLeadDays\",     type number},",
                "            {\"MarketSegment\",       type text},",
                "            {\"SourceOfBusiness\",    type text},",
                "            {\"BookingChannel\",      type text},",
                "            {\"GuestNationality\",    type text},",
                "            {\"CompanyTravelAgent\",  type text},",
                "            {\"VIPCode\",             type text},",
                "            {\"FileRunDate\",         type date},",
                "            {\"FilePeriodFrom\",      type date},",
                "            {\"FilePeriodTo\",        type date}",
                "        }",
                "    ),",
                "",
                "        // ── Step 10: Keep most recent version of each reservation ──",
                "    Grouped = Table.Group(",
                "        WithTypes,",
                "        {\"ConfirmationNumber\"},",
                "        {",
                "            {\"LatestRow\", ",
                "             each",
                "                let",
                "                    sorted = Table.Sort(_, {{\"FileRunDate\", Order.Descending}})",
                "                in",
                "                    sorted{0},",
                "             type record}",
                "        }",
                "    ),",
                "",
                "    ExpandLatest = Table.ExpandRecordColumn(",
                "        Grouped,",
                "        \"LatestRow\",",
                "        {",
                "            \"ReservationStatus\", \"ArrivalDate\", \"DepartureDate\", \"BookingDate\",",
                "            \"Nights\", \"Adults\", \"Children\", \"RoomType\", \"RateCode\", \"RateAmount\",",
                "            \"TotalRateRevenue\", \"BookingLeadDays\", \"MarketSegment\", \"SourceOfBusiness\",",
                "            \"BookingChannel\", \"GuestNationality\", \"CompanyTravelAgent\", \"VIPCode\",",
                "            \"FileRunDate\", \"FilePeriodFrom\", \"FilePeriodTo\"",
                "        }",
                "    ),",
                "",
                "    SortByArrival = Table.Sort(",
                "        ExpandLatest,",
                "        {{\"ArrivalDate\", Order.Ascending}}",
                "    ),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(SortByArrival,{{\"ArrivalDate\", type date}, {\"DepartureDate\", type date}, {\"BookingDate\", type date}, {\"Nights\", Int64.Type}, {\"Adults\", Int64.Type}, {\"Children\", Int64.Type}, {\"RateAmount\", Currency.Type}, {\"TotalRateRevenue\", Currency.Type}, {\"BookingLeadDays\", Int64.Type}, {\"FileRunDate\", type date}, {\"FilePeriodFrom\", type date}, {\"FilePeriodTo\", type date}})",
                "",
                "in",
                "    #\"Changed Type\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
